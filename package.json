{
  "name": "react-intl-locale-chain",
  "version": "0.1.1",
  "description": "Smart locale fallback chains for react-intl",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-intl": ">=5.0.0"
  },
  "devDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsup": "^8.0.0",
    "@types/react": "^18.0.0",
    "jsdom": "^24.0.0"
  },
  "keywords": [
    "react",
    "react-intl",
    "formatjs",
    "i18n",
    "locale",
    "fallback",
    "chain",
    "localization",
    "internationalization"
  ],
  "author": "i18nagent.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/i18n-agent/react-intl-localechain"
  },
  "homepage": "https://github.com/i18n-agent/react-intl-localechain#readme",
  "bugs": {
    "url": "https://github.com/i18n-agent/react-intl-localechain/issues"
  }
}
